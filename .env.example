# Environment Configuration (.env example file)
# Copy to .env and customize as needed

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=0.0.0.0:11434

# API Configuration
DEFAULT_MODEL=llama2
FLASK_ENV=production
FLASK_DEBUG=0
OLLAMA_REQUEST_TIMEOUT=120

# Server Configuration
API_PORT=5000
API_HOST=0.0.0.0

# Security (for production)
# SECRET_KEY=your-secret-key-here

# Database (when adding persistence)
# DATABASE_URL=postgresql://user:password@db:5432/chatbot

# Redis (for caching)
# REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO
MAX_MESSAGE_LENGTH=4000
MAX_HISTORY_MESSAGES=12
MAX_CONTEXT_LENGTH=2200
NUM_RETRIEVED_DOCS=4
MIN_RAG_RELEVANCE=2.0
ENABLE_RAG=true
KNOWLEDGE_DB_PATH=/app/data/knowledge.db

# CORS settings
CORS_ORIGINS=*
